# Telegram Bot credentials (required)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Logging level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

# Set to true to log messages instead of sending them (default: false)
DRY_RUN=false

# Optional: JSON filter configuration
# FILTERS={"min_ram_gb": 16, "max_price": 2000, "categories": ["air", "pro"], "conditions": ["refurbished"]}
FILTERS={}
